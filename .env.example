# Discord OAuth — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# URL exacte autorisée dans le portail Discord (prod : https://ton-site.vercel.app/api/auth/discord/callback)
# Local (npm run dev) : http://localhost:5173/api/auth/discord/callback
DISCORD_REDIRECT_URI=

# Secret aléatoire long pour signer le cookie de session (ex. openssl rand -hex 32)
AUTH_JWT_SECRET=

# IDs Discord autorisés sur /admin et pour les POST /api/tournament/* (séparés par des virgules)
# Ex. : 123456789012345678,987654321098765432
DISCORD_ADMIN_IDS=

# Prod / back distant : https://back.mcsr-game.com
# Stack docker locale (docker-compose.local.yml) : http://localhost:8090
BACKEND_API_BASE_URL=